@Html.AntiForgeryToken()
<div id="toast"></div>

<script>
function showPage(name,navEl){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  var page=document.getElementById('page-'+name);
  if(page)page.classList.add('active');
  if(navEl)navEl.classList.add('active');
  else{var n=document.getElementById('nav-'+name);if(n)n.classList.add('active');}
}
async function updateStatus(accountId, status) {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    if (!confirm(`Are you sure you want to ${status.toLowerCase()} this account?`)) return;
    try {
        const res  = await fetch('/Home/UpdateAccountStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body: JSON.stringify({ accountId, status })
        });
        const data = await res.json();
        if (data.success) {
            const row = document.getElementById(`req-row-${accountId}`);
            if (row) { row.style.opacity = '0'; row.style.transition = 'opacity .3s'; setTimeout(() => row.remove(), 300); }
            const badge = document.querySelector('.nav-badge');
            if (badge) { const count = parseInt(badge.textContent) - 1; if (count <= 0) badge.remove(); else badge.textContent = count; }
            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }
}
function filterTable(input,tbodyId){
  var q=input.value.toLowerCase();
  document.querySelectorAll('#'+tbodyId+' tr').forEach(function(row){
    row.style.display=row.textContent.toLowerCase().includes(q)?'':'none';
  });
}
function showToast(msg,type){
  var t=document.getElementById('toast');
  t.textContent=msg;t.className='show '+type;
  clearTimeout(t._t);t._t=setTimeout(()=>t.className='',3000);
}
function showAddProfessorModal(){
  showToast('Add Professor feature coming soon!', 'ok');
}
function toggleRecentRows() {
    var rows = document.querySelectorAll('.recent-row');
    var btn = document.getElementById('view-all-btn');
    var isExpanded = btn.getAttribute('data-expanded') === 'true';
    
    rows.forEach(function(row, i) {
        if (i >= 5) {
            row.style.display = isExpanded ? 'none' : '';
        }
    });
    
    btn.setAttribute('data-expanded', isExpanded ? 'false' : 'true');
    var total = btn.getAttribute('data-total');
    btn.textContent = isExpanded ? 'View All (' + total + ')' : 'Show Less';
}
function toggleDropdown(btn) {
    // close all other open dropdowns first
    document.querySelectorAll('.dropdown-menu.open').forEach(function(m) {
        if (m !== btn.nextElementSibling) m.classList.remove('open');
    });
    btn.nextElementSibling.classList.toggle('open');
}

// close dropdown when clicking outside
document.addEventListener('click', function(e) {
    if (!e.target.closest('.dropdown-wrap')) {
        document.querySelectorAll('.dropdown-menu.open').forEach(function(m) {
            m.classList.remove('open');
        });
    }
});

function editStudent(accountId) {
    showToast('Edit feature coming soon!', 'ok');
}
async function deleteStudent(accountId) {
    if (!confirm('Are you sure you want to PERMANENTLY delete this account? This cannot be undone.')) return;
    
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    
    try {
        const res = await fetch('/Home/DeleteAccount', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ?? ''
            },
            body: JSON.stringify({ accountId: accountId })
        });
        
        const data = await res.json();
        
        if (data.success) {
            const row = document.querySelector(`[data-account="${accountId}"]`);
            if (row) {
                row.style.opacity = '0';
                row.style.transition = 'opacity .3s';
                setTimeout(() => row.remove(), 300);
            }
            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }
}

async function toggleActivation(accountId, el) {
    const row = document.querySelector(`[data-account="${accountId}"]`);
    const isActive = row.getAttribute('data-active') === 'true';
    const action = isActive ? 'deactivate' : 'reactivate';

    if (!confirm(`Are you sure you want to ${action} this account?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    try {
        const res = await fetch('/Home/ToggleAccountActivation', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ?? ''
            },
            body: JSON.stringify({ accountId: accountId })
        });

        const data = await res.json();

        if (data.success) {
            // update data-active on the row
            row.setAttribute('data-active', data.isActive.toString());

            // update the button text
            const span = el.querySelector('span');
            if (span) span.textContent = data.isActive ? 'Deactivate Account' : 'Reactivate Account';

            // swap the color class
            el.classList.remove('danger', 'reactivate');
            el.classList.add(data.isActive ? 'danger' : 'reactivate');

            // optionally dim the row if deactivated
            row.style.opacity = data.isActive ? '1' : '0.45';

            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }

    // close the dropdown
    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
}
</script>
</body>
</html>
