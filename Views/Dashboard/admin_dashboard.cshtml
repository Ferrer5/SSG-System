async function refreshProfessors() {
    try {
        const res  = await fetch('/Home/GetProfessorsList');
        const data = await res.json();
        if (!data.success) return;

        const tbody = document.getElementById('profs-tb');
        if (!tbody) return;

        if (data.professors.length === 0) {
            tbody.innerHTML = '<tr class="empty-row"><td colspan="4">No professors found.</td></tr>';
            return;
        }

        tbody.innerHTML = data.professors.map((p, i) => `
            <tr>
                <td class="td-mono td-m">${i + 1}</td>
                <td>
                    <strong>${p.fullName}</strong>
                    ${p.role === 'Admin' ? '<span style="font-size:10px;font-weight:600;background:rgba(39,167,68,.15);color:#5fdd8e;border:1px solid rgba(39,167,68,.25);border-radius:5px;padding:1px 7px;margin-left:8px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle;">Admin</span>' : ''}
                </td>
                <td class="td-mono td-m">${p.schoolId}</td>
                <td class="td-m">${p.email}</td>
            </tr>
        `).join('');
    } catch {}
}


    // ── AUTH GUARD WITH OVERLAY ──────────────────────────────────
    const overlay = document.getElementById('auth-overlay');
    let isRedirecting = false; // ← guard flag prevents infinite loop

    function showDashboard() {
        if (!overlay) return;
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
        setTimeout(() => { if (overlay) overlay.remove(); }, 420);
    }

    function hardRedirectToLogin() {
        if (isRedirecting) return; // ← stop if already redirecting
        isRedirecting = true;
        window.location.replace('/');
    }

    function checkAuth() {
        if (isRedirecting) return; // ← stop if already redirecting
        fetch('/Home/CheckAuth?_=' + Date.now(), { cache: 'no-store' })
            .then(r => {
                if (!r.ok) throw new Error('CheckAuth endpoint not found: ' + r.status);
                return r.json();
            })
            .then(data => {
                if (data.authenticated) { showDashboard(); }
                else { hardRedirectToLogin(); }
            })
            .catch((err) => {
                console.error('Auth check failed:', err);
                hardRedirectToLogin();
            });
    }

    // Run on page load
    checkAuth();

    // Run when browser restores from bfcache (mobile swipe-back)
    window.addEventListener('pageshow', function (e) {
        if (e.persisted) {
            isRedirecting = false; // reset flag on fresh page show
            if (overlay) {
                overlay.style.opacity = '1';
                overlay.style.display = 'flex';
                overlay.style.pointerEvents = 'auto';
            }
            checkAuth();
        }
    });

    // Run when tab becomes visible again
    document.addEventListener('visibilitychange', function () {
        if (!document.hidden && !isRedirecting) checkAuth();
    });

    // Trap back button
    history.pushState(null, '', window.location.href);
    window.addEventListener('popstate', function () {
        if (!isRedirecting) {
            checkAuth();
            history.pushState(null, '', window.location.href);
        }
    });
    // ────────────────────────────────────────────────────────────
</script>
</body>
</html>
