async function refreshFees() {
  try {
    const res  = await fetch('/Home/GetFees');
    const data = await res.json();
    if (!data.success) return;

    const tbody = document.getElementById('fee-history-tbody');

    // update summary cards
    const first  = data.fees.find(f => f.semester === 'First'  && f.isLatest);
    const second = data.fees.find(f => f.semester === 'Second' && f.isLatest);

    document.getElementById('fee-1st-val').textContent = first  ? '₱' + parseFloat(first.amount).toFixed(2)  : '₱—';
    document.getElementById('fee-1st-sub').textContent = first  ? first.schoolYear  : 'No fee set';
    document.getElementById('fee-2nd-val').textContent = second ? '₱' + parseFloat(second.amount).toFixed(2) : '₱—';
    document.getElementById('fee-2nd-sub').textContent = second ? second.schoolYear : 'No fee set';

    if (data.fees.length === 0) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="5">No fee records found.</td></tr>';
      return;
    }

    tbody.innerHTML = data.fees.map(f => `
      <tr>
        <td><strong>${f.schoolYear}</strong></td>
        <td><span class="badge ${f.semester === 'First' ? 'bg' : 'by'}">${f.semester === 'First' ? '1st' : '2nd'}</span></td>
        <td class="td-mono">₱${parseFloat(f.amount).toFixed(2)}</td>
        <td>
          ${f.semesterStatus === 'Current'
            ? '<span class="badge bg">Current</span>'
            : '<span class="badge" style="background:rgba(255,255,255,.05);color:var(--text-d)">Ended</span>'}
        </td>
        <td style="text-align:right">
          <button class="btn-danger" onclick="deleteFee(${f.fullAmountId})" style="font-size:11px;padding:5px 12px">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Delete
          </button>
        </td>
      </tr>
    `).join('');

    // refresh school year dropdown
    await refreshSchoolYears();
  } catch {}
}

async function deleteFee(fullAmountId) {
  if (!confirm('Delete this fee record?')) return;
  try {
    const res  = await fetch('/Home/DeleteFee', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body:    JSON.stringify({ fullAmountId })
    });
    const data = await res.json();
    if (data.success) { showToast(data.message, 'ok'); await refreshFees(); }
    else showToast(data.message, 'fail');
  } catch { showToast('Request failed.', 'fail'); }
}

// ── INIT ─────────────────────────────────────────────────────────
async function init() {
  await loadCurrentSemesterInfo();
  await renderDashboard();
  await loadStudents();
  setTimeout(renderCharts, 200);
}

init();

