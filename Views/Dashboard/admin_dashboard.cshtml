@model MyMvcApp.Models.DashboardViewModel
@{
    Layout = null;
    var firstName = Context.Session.GetString("FirstName") ?? "Admin";
    var lastName  = Context.Session.GetString("LastName") ?? "";
    var schoolId  = Context.Session.GetString("SchoolId") ?? "";
    var initials  = (firstName.Length > 0 ? firstName[0].ToString() : "") + (lastName.Length > 0 ? lastName[0].ToString() : "");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSG Finance — Admin Panel</title>
    <link rel="icon" type="image/png" href="~/favicon.png">
    <link rel="stylesheet" href="~/css/dashboard.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --sidebar-bg:   #0a2218;
            --sidebar-w:    200px;
            --accent:       #2e7d52;
            --accent-light: #34a865;
            --main-bg:      #0d1f17;
            --card-bg:      #ffffff;
            --card-border:  #e5e7eb;
            --text-dark:    #111827;
            --text-mid:     #6b7280;
            --text-light:   #9ca3af;
            --green-badge:  #dcfce7;
            --green-text:   #166534;
            --yellow-badge: #fef9c3;
            --yellow-text:  #854d0e;
            --red-text:     #dc2626;
            --red-bg:       #fee2e2;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--main-bg);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            top: 0; left: 0;
            z-index: 100;
            padding-bottom: 16px;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 20px 16px 18px;
            border-bottom: 1px solid rgba(255,255,255,.07);
        }

        .brand-avatar {
            width: 38px; height: 38px;
            border-radius: 50%;
            background: var(--accent);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            overflow: hidden;
        }

        .brand-avatar img { width: 100%; height: 100%; object-fit: cover; }

        .brand-avatar svg { width: 22px; height: 22px; }

        .brand-text { min-width: 0; }
        .brand-name { font-size: 14px; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .brand-role { font-size: 11px; color: rgba(255,255,255,.45); margin-top: 1px; }

        .nav-section-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: rgba(255,255,255,.3);
            padding: 16px 16px 6px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 16px;
            margin: 1px 8px;
            border-radius: 8px;
            font-size: 13.5px;
            color: rgba(255,255,255,.55);
            cursor: pointer;
            transition: background .15s, color .15s;
            position: relative;
            text-decoration: none;
        }

        .nav-item:hover { background: rgba(255,255,255,.07); color: rgba(255,255,255,.85); }

        .nav-item.active {
            background: var(--accent);
            color: #fff;
        }

        .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }

        .nav-badge {
            margin-left: auto;
            background: #dc2626;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            min-width: 18px;
            height: 18px;
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            padding: 0 5px;
        }

        .sidebar-spacer { flex: 1; }

        .sidebar-user {
            padding: 12px 16px 6px;
            border-top: 1px solid rgba(255,255,255,.07);
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            border-radius: 8px;
            background: rgba(255,255,255,.05);
            margin-bottom: 6px;
        }

        .user-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            background: var(--accent);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700; color: #fff;
            flex-shrink: 0;
        }

        .user-name { font-size: 12.5px; font-weight: 500; color: #fff; }
        .user-role { font-size: 11px; color: rgba(255,255,255,.4); }

        .signout-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border-radius: 8px;
            font-size: 12.5px;
            color: rgba(255,255,255,.4);
            cursor: pointer;
            transition: background .15s, color .15s;
        }

        .signout-btn:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.7); }

        .signout-btn svg { width: 15px; height: 15px; }

        /* ── MAIN ── */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            padding: 32px 32px 48px;
            min-height: 100vh;
        }

        .page { display: none; }
        .page.active { display: block; }

        .page-title {
            font-size: 26px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 24px;
        }

        /* ── STAT CARDS ── */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: var(--card-bg);
            border-radius: 12px;
            padding: 22px 24px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .stat-header {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-mid);
        }

        .stat-icon {
            width: 32px; height: 32px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
        }

        .stat-icon.green { background: var(--green-badge); }
        .stat-icon.yellow { background: var(--yellow-badge); }
        .stat-icon.red { background: var(--red-bg); }
        .stat-icon svg { width: 18px; height: 18px; }

        .stat-value {
            font-size: 36px;
            font-weight: 700;
            color: var(--text-dark);
            line-height: 1;
        }

        .stat-sub {
            font-size: 12px;
            color: var(--accent-light);
            font-weight: 500;
        }

        .stat-sub.warn { color: #ca8a04; }
        .stat-sub.danger { color: #dc2626; }

        /* ── CONTENT CARD ── */
        .content-card {
            background: var(--card-bg);
            border-radius: 12px;
            padding: 22px 24px;
            margin-bottom: 20px;
        }

        .content-card-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 16px;
        }

        /* ── TABLE ── */
        .tbl-wrap { overflow-x: auto; }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        thead th {
            padding: 10px 14px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--text-light);
            border-bottom: 1px solid var(--card-border);
            text-align: left;
            white-space: nowrap;
        }

        tbody tr { border-bottom: 1px solid #f3f4f6; transition: background .1s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #f9fafb; }

        td {
            padding: 13px 14px;
            color: var(--text-dark);
            vertical-align: middle;
        }

        .td-mid { color: var(--text-mid); }
        .td-mono { font-family: 'SF Mono', monospace; font-size: 12px; }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-green  { background: var(--green-badge);  color: var(--green-text); }
        .badge-yellow { background: var(--yellow-badge); color: var(--yellow-text); }
        .badge-red    { background: var(--red-bg);       color: var(--red-text); }

        .action-btns { display: flex; gap: 6px; }

        .btn-approve, .btn-reject {
            padding: 5px 14px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid transparent;
            transition: opacity .15s;
            font-family: inherit;
        }

        .btn-approve { background: #fff; color: var(--green-text); border-color: #86efac; }
        .btn-approve:hover { background: var(--green-badge); }
        .btn-reject  { background: #fff; color: var(--red-text);   border-color: #fca5a5; }
        .btn-reject:hover  { background: var(--red-bg); }

        .empty-row td { text-align: center; padding: 36px; color: var(--text-light); font-size: 13px; }

        /* ── TOOLBAR ── */
        .toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
            gap: 12px;
            flex-wrap: wrap;
        }

        .search-input {
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid var(--card-border);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 13px;
            color: var(--text-mid);
            background: #fff;
            min-width: 220px;
        }

        .search-input input {
            border: none;
            outline: none;
            font-family: inherit;
            font-size: 13px;
            color: var(--text-dark);
            width: 100%;
            background: transparent;
        }

        .search-input input::placeholder { color: var(--text-light); }
        .search-input svg { width: 16px; height: 16px; flex-shrink: 0; color: var(--text-light); }

        .btn-primary {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 9px 18px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            font-family: inherit;
            transition: background .15s;
        }

        .btn-primary:hover { background: var(--accent-light); }
        .btn-primary svg { width: 16px; height: 16px; }

        /* ── VIEW ALL ── */
        .view-all-wrap { display: flex; justify-content: center; margin-top: 16px; }

        .btn-outline {
            padding: 8px 28px;
            border: 1px solid var(--card-border);
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-mid);
            background: #fff;
            cursor: pointer;
            font-family: inherit;
            transition: border-color .15s, color .15s;
        }

        .btn-outline:hover { border-color: #9ca3af; color: var(--text-dark); }

        /* ── CHART PLACEHOLDER ── */
        .chart-placeholder {
            height: 180px;
            background: #f9fafb;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-light);
            font-size: 13px;
            border: 1px dashed var(--card-border);
        }

        /* ── TOAST ── */
        #toast {
            position: fixed;
            bottom: 24px; right: 24px;
            padding: 12px 20px;
            border-radius: 10px;
            font-size: 13px; font-weight: 500;
            background: #1f2937;
            color: #fff;
            opacity: 0; transform: translateY(8px);
            transition: opacity .25s, transform .25s;
            z-index: 999; pointer-events: none;
        }
        #toast.show   { opacity: 1; transform: translateY(0); }
        #toast.ok     { background: #14532d; }
        #toast.fail   { background: #7f1d1d; }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); transition: transform .25s; }
            body.sidebar-open .sidebar { transform: translateX(0); }
            .main { margin-left: 0; padding: 20px 16px; }
        }
    </style>
</head>
<body>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-avatar">
            <svg viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="#fff" stroke-width="1.8"/>
                <path d="M8 12l3 3 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <div class="brand-text">
            <div class="brand-name">SSG Finance</div>
            <div class="brand-role">Admin Panel</div>
        </div>
    </div>

    <div class="nav-section-label">Main</div>
    <a class="nav-item active" id="nav-dashboard" onclick="showPage('dashboard')">
        <svg viewBox="0 0 24 24" fill="none">
            <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
            <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
            <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
            <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        Dashboard
    </a>
     <a class="nav-item" id="nav-requests" onclick="showPage('requests')">
        <svg viewBox="0 0 24 24" fill="none">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        Requests
        @if ((Model.RequestedAccounts?.Count ?? 0) > 0)
        {
            <span class="nav-badge">@Model.RequestedAccounts!.Count</span>
        }
    </a>

    <div class="nav-section-label">Users</div>
    <a class="nav-item" id="nav-students" onclick="showPage('students')">
        <svg viewBox="0 0 24 24" fill="none">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        Students
    </a>

    <a class="nav-item" id="nav-treasurers" onclick="showPage('treasurers')">
        <svg viewBox="0 0 24 24" fill="none">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        Treasurers
    </a>

    <a class="nav-item" id="nav-professors" onclick="showPage('professors')">
        <svg viewBox="0 0 24 24" fill="none">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        Professors
    </a>

    <a class="nav-item" id="nav-admins" onclick="showPage('admins')">
        <svg viewBox="0 0 24 24" fill="none">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        Admins
    </a>

    
    <div class="nav-section-label">System</div>
    <a class="nav-item" id="nav-settings" onclick="showPage('settings')">
        <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="1.8"/>
            <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        Settings
    </a>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-user">
        <div class="user-card">
            <div class="user-avatar">@initials.ToUpper()</div>
            <div>
                <div class="user-name">@(lastName.Length > 0 ? $"Ms. {lastName}" : firstName)</div>
                <div class="user-role">Admin</div>
            </div>
        </div>
        <div class="signout-btn" onclick="window.location.href='@Url.Action("Logout", "Home")'">
            <svg viewBox="0 0 24 24" fill="none">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Sign Out
        </div>
    </div>
</aside>

<!-- ── MAIN ── -->
<div class="main">

    <!-- ═══ DASHBOARD PAGE ═══ -->
    <div class="page active" id="page-dashboard">
        <div class="page-title">Dashboard</div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon green">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round"/>
                            <circle cx="9" cy="7" r="4" stroke="#16a34a" stroke-width="1.8"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                    </div>
                    Registered Accounts
                </div>
                <div class="stat-value">@Model.ApprovedAccountsCount</div>
                <div class="stat-sub">All Approved Accounts in the system</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon yellow">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="#ca8a04" stroke-width="1.8" stroke-linecap="round"/>
                            <circle cx="12" cy="7" r="4" stroke="#ca8a04" stroke-width="1.8"/>
                        </svg>
                    </div>
                    Requests
                </div>
                <div class="stat-value">@(Model.RequestedAccounts?.Count ?? 0)</div>
                <div class="stat-sub warn">Awaiting Review</div>
            </div>
        </div>

        <!-- Recent Account Requests -->
        <div class="content-card">
            <div class="content-card-title">Recent Account Requests</div>
            <div class="tbl-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Year &amp; Section</th>
                            <th>Course</th>
                            <th>Email</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.AllAccountRequests != null && Model.AllAccountRequests.Any())
                        {
                            @foreach (var acct in Model.AllAccountRequests.Take(5))
                            {
                                <tr>
                                    <td class="td-mono td-mid">@(acct.StudentId ?? "—")</td>
                                    <td><strong>@acct.Fullname</strong></td>
                                    <td class="td-mid">@(acct.YearLevel ?? "—")-@(acct.Section ?? "—")</td>
                                    <td class="td-mid">@(acct.CourseCode ?? "—")</td>
                                    <td class="td-mid">—</td>
                                    <td class="td-mono td-mid">@acct.CreatedAt.ToString("MM-d-yyyy")</td>
                                    <td>
                                        @{
                                            var statusClass = acct.Status switch
                                            {
                                                RequestStatus.Pending => "badge-yellow",
                                                RequestStatus.Approved => "badge-green", 
                                                RequestStatus.Rejected => "badge-red",
                                                _ => "badge-gray"
                                            };
                                        }
                                        <span class="badge @statusClass">@acct.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr class="empty-row"><td colspan="7">No account requests found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            @if ((Model.AllAccountRequests?.Count ?? 0) > 5)
            {
                <div class="view-all-wrap">
                    <button class="btn-outline" onclick="showPage('requests')">View All</button>
                </div>
            }
        </div>
    </div>

    <!-- ═══ STUDENTS PAGE ═══ -->
    <div class="page" id="page-students">
        <div class="page-title">Students</div>
        <div class="content-card">
            <div class="toolbar">
                <div class="search-input">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
                    <input type="text" id="student-search" placeholder="Search by name or course…" oninput="filterStudents()" />
                </div>
