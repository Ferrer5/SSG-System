
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SSG Financial Management System</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>

    <!-- HEADER -->
    <header class="header">
        <button class="hamburger" onclick="toggleSidebar()" aria-label="Menu">
            <svg width="22" height="22" fill="none" stroke="white" stroke-width="2.2" viewBox="0 0 24 24">
                <line x1="3" y1="6"  x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
        </button>
        <div class="header-logo">🌿</div>
        <h1>SSG Financial Management System</h1>
    </header>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <nav class="nav-menu">
            <a class="nav-item active" href="#">
                <svg class="nav-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                    <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
                Dashboard
            </a>
            <a class="nav-item" href="#">
                <svg class="nav-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
                    <rect x="9" y="3" width="6" height="4" rx="1"/>
                    <line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="12" y2="16"/>
                </svg>
                Transactions
            </a>
            <a class="nav-item" href="#">
                <svg class="nav-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 17v-2m3 2v-4m3 4v-6M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Reports
            </a>
            <a class="nav-item" href="#">
                <svg class="nav-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
                </svg>
                Settings
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">M</div>
                <div>
                    <div class="user-name">Ms. Cadungog</div>
                    <div class="user-role">Admin</div>
                </div>
            </div>
            <div class="sign-out" onclick="window.location.href='@Url.Action("Index", "Home")'">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Sign Out
            </div>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main">

        <!-- STAT CARDS -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <svg fill="none" stroke="#2196f3" stroke-width="2" viewBox="0 0 24 24">
                        <line x1="12" y1="19" x2="12" y2="5"/>
                        <polyline points="5 12 12 5 19 12"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-value">₱ 20,000.00</div>
                    <div class="stat-label">Total Funds Collected</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon red">
                    <svg fill="none" stroke="#f44336" stroke-width="2" viewBox="0 0 24 24">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <polyline points="19 12 12 19 5 12"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-value">₱ 20,000.00</div>
                    <div class="stat-label">Total Expenses</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon yellow">
                    <svg fill="none" stroke="#ffc107" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-value">98</div>
                    <div class="stat-label">Account Request</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon green">
                    <svg fill="none" stroke="#4caf50" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-value">245</div>
                    <div class="stat-label">Registered Students</div>
                </div>
            </div>
        </div>

        <!-- MIDDLE ROW: Chart + Students Profile -->
        <div class="mid-row">

            <!-- Financial Overview -->
            <div class="panel">
                <div class="panel-title">Financial Overview</div>
                <div class="chart-legend">
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#2196f3"></div>
                        Monthly Collected Funds
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#f44336"></div>
                        Monthly Expenses
                    </div>
                </div>
                <canvas id="financeChart" height="180"></canvas>
            </div>

            <!-- Students Profile -->
            <div class="panel">
                <div class="panel-title">Students Profile</div>
                <div class="search-box">
                    <svg class="search-icon" fill="none" stroke="#aaa" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" placeholder="Search by ID or name" id="studentSearch" oninput="filterStudents()" />
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Course</th>
                            <th>Year & Section</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="studentTable">
                        <tr>
                            <td>ARIAS, RONALD C.</td>
                            <td>BSIT</td>
                            <td>2 - A</td>
                            <td><button class="btn-edit">✏ Edit</button></td>
                        </tr>
                        <tr>
                            <td>MELGAR, SHEENA B</td>
                            <td>BSIT</td>
                            <td>2 - A</td>
                            <td><button class="btn-edit">✏ Edit</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Requested Accounts -->
        <div class="full-panel">
            <div class="panel-title">Requested Accounts</div>
            <div class="search-box" style="max-width:320px">
                <svg class="search-icon" fill="none" stroke="#aaa" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" placeholder="Search by ID or name" id="requestSearch" oninput="filterRequests()" />
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Student ID</th>
                        <th>Name</th>
                        <th>Course</th>
                        <th>Year & Section</th>
                        <th>Date Requested</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="requestTable">
                    <tr>
                        <td>724211</td>
                        <td>FERRER, JANREY</td>
                        <td>BSIT</td>
                        <td>2-A</td>
                        <td>4-1-2026</td>
                        <td><span class="status-pending">Pending</span></td>
                        <td><span class="action-dots">•••</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

    </main>

    <script>
        // ── Chart ──
        const ctx = document.getElementById('financeChart').getContext('2d');
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: months,
                datasets: [
                    {
                        label: 'Monthly Collected Funds',
                        data: [153000,165000,150000,120000,138000,160000,142000,180000,175000,165000,171000,200000],
                        borderColor: '#2196f3',
                        backgroundColor: 'rgba(33,150,243,.08)',
                        borderWidth: 2.2,
                        pointRadius: 4,
                        pointBackgroundColor: '#2196f3',
                        tension: 0.4,
                        fill: false
                    },
                    {
                        label: 'Monthly Expenses',
                        data: [95000,82000,98000,92000,100000,95000,88000,96000,94000,98000,160000,160000],
                        borderColor: '#f44336',
                        backgroundColor: 'rgba(244,67,54,.08)',
                        borderWidth: 2.2,
                        pointRadius: 4,
                        pointBackgroundColor: '#f44336',
                        tension: 0.4,
                        fill: false
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { font: { size: 10 }, callback: v => v >= 1000 ? (v/1000)+'k' : v },
                        grid: { color: '#f0f0f0' },
                        title: { display: true, text: 'Collection (in ₱)', font: { size: 10 }, color: '#888' }
                    },
                    x: {
                        ticks: { font: { size: 10 } },
                        grid: { display: false },
                        title: { display: true, text: 'Month', font: { size: 10 }, color: '#888' }
                    }
                }
            }
        });

        // ── Search: Students ──
        function filterStudents() {
            const val = document.getElementById('studentSearch').value.toLowerCase();
            document.querySelectorAll('#studentTable tr').forEach(tr => {
                tr.style.display = tr.innerText.toLowerCase().includes(val) ? '' : 'none';
            });
        }

        // ── Search: Requests ──
        function filterRequests() {
            const val = document.getElementById('requestSearch').value.toLowerCase();
            document.querySelectorAll('#requestTable tr').forEach(tr => {
                tr.style.display = tr.innerText.toLowerCase().includes(val) ? '' : 'none';
            });
        }

        // ── Mobile sidebar toggle ──
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
        }
    </script>
</body>
</html>
