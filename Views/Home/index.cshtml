@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSG Finance System</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Ionicons -->
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>

    <style>
        :root {
            --gold: #c8a96e;
            --gold-light: #e2c99a;
            --white: #ffffff;
            --dark: rgba(0, 0, 0, 0.55);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            overflow: hidden;
            height: 100vh;
        }

        /* ── HERO ── */
        .hero {
            position: relative;
            width: 100%;
            height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--white);
            overflow: hidden;
        }

        /* Background image */
        .hero-bg {
            position: absolute;
            inset: 0;
            background: url('/images/CtuGinatilan.jpg') no-repeat center / cover;
            filter: blur(3px);
            transform: scale(1.08);
            z-index: 0;
            transition: filter 1.2s ease;
        }

        /* Gradient overlay — darker at top & bottom, lighter in center */
        .hero-overlay {
            position: absolute;
            inset: 0;
            background:
                linear-gradient(to bottom,
                    rgba(0,0,0,0.72) 0%,
                    rgba(0,0,0,0.35) 40%,
                    rgba(0,0,0,0.38) 65%,
                    rgba(0,0,0,0.68) 100%);
            z-index: 1;
        }

        /* Gold accent line at very top */
        .top-accent {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            z-index: 10;
        }

        /* ── CONTENT ── */
        .hero-content {
            position: relative;
            z-index: 5;
            display: flex;
            flex-direction: column;
            height: 100%;
            padding: 0 72px;
        }

        /* ── NAVBAR ── */
        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 28px 0 24px;
            border-bottom: 1px solid rgba(255,255,255,0.12);
            animation: fadeDown 0.8s ease both;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo img {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 2px solid var(--gold);
            object-fit: cover;
            box-shadow: 0 0 14px rgba(200,169,110,0.4);
        }

        .logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1.15;
        }

        .logo-text .brand {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.02em;
            color: var(--white);
        }

        .logo-text .sub {
            font-size: 10px;
            letter-spacing: 0.14em;
            color: var(--gold-light);
            text-transform: uppercase;
            font-weight: 500;
        }

        /* NAV LINKS */
        .nav-links {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .nav-links a {
            text-decoration: none;
            color: rgba(255,255,255,0.82);
            font-size: 13.5px;
            font-weight: 500;
            letter-spacing: 0.04em;
            padding: 7px 14px;
            border-radius: 6px;
            transition: all 0.25s ease;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 4px;
            left: 50%;
            transform: translateX(-50%) scaleX(0);
            width: 60%;
            height: 1.5px;
            background: var(--gold);
            border-radius: 2px;
            transition: transform 0.25s ease;
        }

        .nav-links a:hover {
            color: var(--white);
            background: rgba(255,255,255,0.07);
        }

        .nav-links a:hover::after {
            transform: translateX(-50%) scaleX(1);
        }

        .nav-links a.active {
            color: var(--white);
        }

        .nav-links a.nav-login {
            background: rgba(200,169,110,0.18);
            border: 1px solid var(--gold);
            color: var(--gold-light);
            border-radius: 20px;
            padding: 7px 20px;
            margin-left: 8px;
        }

        .nav-links a.nav-login:hover {
            background: var(--gold);
            color: #1a1208;
        }

        .nav-links a.nav-login::after { display: none; }

        /* CLOCK */
        .clock {
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.06em;
            color: rgba(255,255,255,0.75);
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            padding: 7px 14px;
            border-radius: 8px;
            backdrop-filter: blur(8px);
            min-width: 130px;
            text-align: center;
        }

        /* ── MAIN SECTION ── */
        .main-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding-bottom: 60px;
            max-width: 680px;
        }

        .eyebrow {
            font-size: 11px;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--gold);
            font-weight: 600;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: fadeUp 0.7s 0.2s ease both;
        }

        .eyebrow::before {
            content: '';
            display: inline-block;
            width: 28px;
            height: 1.5px;
            background: var(--gold);
            border-radius: 2px;
        }

        .main-title {
            font-family: 'Inter', sans-serif;
            font-size: clamp(38px, 5vw, 58px);
            font-weight: 700;
            line-height: 1.12;
            margin-bottom: 14px;
            letter-spacing: -0.01em;
            animation: fadeUp 0.7s 0.35s ease both;
        }

        .main-title span {
            color: var(--gold-light);
        }

        .main-desc {
            font-size: 15px;
            color: rgba(255,255,255,0.65);
            line-height: 1.7;
            margin-bottom: 40px;
            max-width: 480px;
            font-weight: 300;
            animation: fadeUp 0.7s 0.5s ease both;
        }

        /* SEARCH BOX */
        .search-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            animation: fadeUp 0.7s 0.65s ease both;
        }

        .search-box {
            flex: 1;
            max-width: 480px;
            display: flex;
            align-items: center;
            background: rgba(255,255,255,0.09);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 12px;
            padding: 0 20px;
            gap: 12px;
            backdrop-filter: blur(12px);
            transition: border-color 0.3s, background 0.3s;
        }

        .search-box:focus-within {
            border-color: var(--gold);
            background: rgba(255,255,255,0.13);
        }

        .search-box ion-icon {
            font-size: 18px;
            color: rgba(255,255,255,0.45);
            flex-shrink: 0;
        }

        .search-box input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: white;
            font-size: 15px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 400;
            padding: 16px 0;
        }

        .search-box input::placeholder {
            color: rgba(255,255,255,0.4);
        }

        .btn-search {
            padding: 15px 32px;
            border-radius: 12px;
            border: none;
            background: var(--gold);
            color: #1a1208;
            font-size: 14px;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            letter-spacing: 0.05em;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.25s ease;
            white-space: nowrap;
        }

        .btn-search:hover {
            background: var(--gold-light);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(200,169,110,0.35);
        }

        .btn-search ion-icon {
            font-size: 16px;
        }

        /* ── BOTTOM STRIP ── */
        .bottom-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 5;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 72px;
            border-top: 1px solid rgba(255,255,255,0.1);
            background: rgba(0,0,0,0.25);
            backdrop-filter: blur(6px);
            animation: fadeUp 0.7s 0.9s ease both;
        }

        .bottom-bar p {
            font-size: 12px;
            color: rgba(255,255,255,0.4);
            letter-spacing: 0.04em;
        }

        .bottom-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--gold);
            font-weight: 500;
            letter-spacing: 0.08em;
        }

        .bottom-badge span {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #4ade80;
            display: inline-block;
            box-shadow: 0 0 6px #4ade80;
        }

        /* ── ANIMATIONS ── */
        @@keyframes fadeDown {
            from { opacity: 0; transform: translateY(-16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 900px) {
            .hero-content { padding: 0 28px; }
            .bottom-bar   { padding: 16px 28px; }
            .nav-links a  { font-size: 12.5px; padding: 6px 10px; }
            .clock        { display: none; }
        }

        @@media (max-width: 640px) {
            .nav-links { gap: 2px; }
            .nav-links a:not(.nav-login) { display: none; }
            .main-title { font-size: 34px; }
            .search-wrapper { flex-direction: column; align-items: stretch; }
            .search-box { max-width: 100%; }
        }
    </style>
</head>

<body>
    <div class="hero">
        <div class="top-accent"></div>
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>

        <div class="hero-content">

            <!-- NAVBAR -->
            <nav class="navbar">
                <div class="logo">
                    <img src="/images/logo.png" alt="SSG Logo">
                    <div class="logo-text">
                        <span class="brand">Admission Portal</span>
                        <span class="sub">SSG Finance System</span>
                    </div>
                </div>

                <div class="nav-links">
                    <a href="#" class="active">Home</a>
                    <a href="#" target="_blank">University Website</a>
                    <a href="#">About</a>
                    <a href="#">FAQ</a>
                    <a href="#">Contacts</a>
                    <a href="/Home/Login" class="nav-login">Login</a>
                </div>

                <div id="clock" class="clock"></div>
            </nav>

            <!-- MAIN -->
            <div class="main-section">
                <p class="eyebrow">Student Government Finance</p>
                <h1 class="main-title">Track your<br><span>Application</span></h1>
                <p class="main-desc">
                    Easily monitor your organizational fee status, track submissions, and stay updated with the SSG Finance System.
                </p>

                <div class="search-wrapper">
                    <div class="search-box">
                        <ion-icon name="search-outline"></ion-icon>
                        <input type="text" placeholder="Enter your Student ID or Name…" id="trackInput">
                    </div>
                    <button class="btn-search" onclick="handleSearch()">
                        Search
                        <ion-icon name="arrow-forward-outline"></ion-icon>
                    </button>
                </div>
            </div>

        </div>

        <!-- BOTTOM BAR -->
        <div class="bottom-bar">
            <p>© 2025 SSG Finance System · Cebu Technological University</p>
            <div class="bottom-badge">
                <span></span>
                System Online
            </div>
        </div>
    </div>

    <script>
        // Real-time clock
        function updateClock() {
            const now = new Date();
            let h = now.getHours();
            const m = String(now.getMinutes()).padStart(2, '0');
            const s = String(now.getSeconds()).padStart(2, '0');
            const ampm = h >= 12 ? 'PM' : 'AM';
            h = h % 12 || 12;
            document.getElementById('clock').textContent = `${h}:${m}:${s} ${ampm}`;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Search handler (wire up to your route)
        function handleSearch() {
            const val = document.getElementById('trackInput').value.trim();
            if (!val) return;
            // Update this URL to your actual tracking endpoint
            window.location.href = `/Home/Track?query=${encodeURIComponent(val)}`;
        }

        // Allow Enter key to search
        document.getElementById('trackInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') handleSearch();
        });
    </script>
</body>
</html>
