@{
    ViewData["Title"] = "Treasurer Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate, private, max-age=0">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>Treasurer Dashboard</title>
    <style>
        /* ── LOADING OVERLAY ── */
#auth-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg, #071a0c);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    transition: opacity 0.4s ease;
}

#auth-overlay.fade-out {
    opacity: 0;
    pointer-events: none;
}

.overlay-spinner {
    width: 42px;
    height: 42px;
    border: 3px solid rgba(39, 167, 68, 0.2);
    border-top-color: #27a744;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

.overlay-logo {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, #1a7a4a, #27a744);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 24px rgba(39, 167, 68, 0.3);
}

.overlay-text {
    font-size: 13px;
    font-weight: 500;
    color: rgba(232, 245, 236, 0.5);
    letter-spacing: 0.06em;
}

.overlay-dots::after {
    content: '';
    animation: dots 1.4s steps(4, end) infinite;
}

@@keyframes dots {
    0%   { content: '';   }
    25%  { content: '.';  }
    50%  { content: '..'; }
    75%  { content: '...'; }
}

@@keyframes spin {
    to { transform: rotate(360deg); }
}
    </style>
    </head>
<body>

<!-- ── AUTH LOADING OVERLAY — sits on top of everything until auth is confirmed ── -->
<div id="auth-overlay">
    <div class="overlay-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                  stroke="#fff" stroke-width="1.8"
                  stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </div>
    <div class="overlay-spinner"></div>
    <p class="overlay-text">Verifying session<span class="overlay-dots"></span></p>
</div>

<!-- rest of your existing dashboard HTML below -->

<div style="padding: 24px; font-family: Arial, sans-serif;">
    <h2>Treasurer Dashboard</h2>
    <p>Welcome, @Context.Session.GetString("FirstName") @Context.Session.GetString("LastName").</p>
    <p>Role: @Context.Session.GetString("UserRole")</p>
</div>

<script>
    // ── AUTH GUARD WITH OVERLAY ──────────────────────────────────
    const overlay = document.getElementById('auth-overlay');
    let isRedirecting = false; // ← guard flag prevents infinite loop

    function showDashboard() {
        if (!overlay) return;
        overlay.classList.add('fade-out');
        setTimeout(() => { if (overlay) overlay.remove(); }, 420);
    }

    function hardRedirectToLogin() {
        if (isRedirecting) return; // ← stop if already redirecting
        isRedirecting = true;
        window.location.replace('/');
    }

    function checkAuth() {
        if (isRedirecting) return; // ← stop if already redirecting
        fetch('/Home/CheckAuth?_=' + Date.now(), { cache: 'no-store' })
            .then(r => {
                if (!r.ok) throw new Error('CheckAuth endpoint not found: ' + r.status);
                return r.json();
            })
            .then(data => {
                if (data.authenticated) { showDashboard(); }
                else { hardRedirectToLogin(); }
            })
            .catch((err) => {
                console.error('Auth check failed:', err);
                hardRedirectToLogin();
            });
    }

    // Run on page load
    checkAuth();

    // Run when browser restores from bfcache (mobile swipe-back)
    window.addEventListener('pageshow', function (e) {
        if (e.persisted) {
            isRedirecting = false; // reset flag on fresh page show
            if (overlay) {
                overlay.style.opacity = '1';
                overlay.style.display = 'flex';
                overlay.classList.remove('fade-out');
            }
            checkAuth();
        }
    });

    // Run when tab becomes visible again
    document.addEventListener('visibilitychange', function () {
        if (!document.hidden && !isRedirecting) checkAuth();
    });

    // Trap back button
    history.pushState(null, '', window.location.href);
    window.addEventListener('popstate', function () {
        if (!isRedirecting) {
            checkAuth();
            history.pushState(null, '', window.location.href);
        }
    });
    // ────────────────────────────────────────────────────────────
</script>
</body>
</html>
