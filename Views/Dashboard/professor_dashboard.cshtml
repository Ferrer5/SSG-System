@{
    ViewData["Title"] = "Professor Dashboard";
    Layout = null;
    var firstName = Context.Session.GetString("FirstName") ?? "Professor";
    var lastName = Context.Session.GetString("LastName") ?? "";
    var schoolId = Context.Session.GetString("SchoolId") ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate, private, max-age=0">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>Professor Dashboard - SSG Financial Management</title>
    <link rel="icon" type="image/png" href="~/favicon.png">
    <link rel="stylesheet" href="~/css/dashboard.css">
    <style>
        /* ── LOADING OVERLAY ── */
#auth-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg, #071a0c);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    transition: opacity 0.4s ease;
}

#auth-overlay.fade-out {
    opacity: 0;
    pointer-events: none;
}

.overlay-spinner {
    width: 42px;
    height: 42px;
    border: 3px solid rgba(39, 167, 68, 0.2);
    border-top-color: #27a744;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

.overlay-logo {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, #1a7a4a, #27a744);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 24px rgba(39, 167, 68, 0.3);
}

.overlay-text {
    font-size: 13px;
    font-weight: 500;
    color: rgba(232, 245, 236, 0.5);
    letter-spacing: 0.06em;
}

.overlay-dots::after {
    content: '';
    animation: dots 1.4s steps(4, end) infinite;
}

@@keyframes dots {
    0%   { content: '';   }
    25%  { content: '.';  }
    50%  { content: '..'; }
    75%  { content: '...'; }
}

@@keyframes spin {
    to { transform: rotate(360deg); }
}
    </style>
    </head>
<body>

<!-- ── AUTH LOADING OVERLAY — sits on top of everything until auth is confirmed ── -->
<div id="auth-overlay">
    <div class="overlay-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                  stroke="#fff" stroke-width="1.8"
                  stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </div>
    <div class="overlay-spinner"></div>
    <p class="overlay-text">Verifying session<span class="overlay-dots"></span></p>
</div>

<!-- rest of your existing dashboard HTML below -->

<!-- HEADER -->
<div class="header">
  <button class="burger-menu" onclick="toggleSidebar()" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
  </button>
  <div class="header-logo">
    <svg viewBox="0 0 24 24" fill="none">
      <circle cx="12" cy="12" r="10" stroke="#32b357" stroke-width="2"/>
      <path d="M8 12l3 3 5-5" stroke="#32b357" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <div class="header-title">Professor Dashboard</div>
</div>

<!-- MOBILE OVERLAY -->
<div class="mobile-overlay" onclick="closeSidebar()"></div>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="nav-list">
    <div class="nav-item active" id="nav-dashboard" onclick="showPage('dashboard')">
      <svg viewBox="0 0 24 24" fill="none">
        <rect x="3" y="3" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
        <rect x="13" y="3" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
        <rect x="3" y="13" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
        <rect x="13" y="13" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
      </svg>
      <span class="nav-label">Dashboard</span>
    </div>
    <div class="nav-item" id="nav-students" onclick="showPage('students')">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8"/>
        <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8"/>
      </svg>
      <span class="nav-label">My Students</span>
    </div>
    <div class="nav-item" id="nav-reports" onclick="showPage('reports')">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M9 17H5a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M13 21l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M9 7h6M9 11h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="nav-label">Reports</span>
    </div>
    <div class="nav-item" id="nav-settings" onclick="showPage('settings')">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="1.8"/>
        <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="1.8"/>
      </svg>
      <span class="nav-label">Settings</span>
    </div>
  </div>

  <div class="sidebar-bottom">
    <div class="user-card">
      <div class="user-avatar">@firstName.Substring(0, 1)</div>
      <div class="user-info">
        <div class="user-name">@firstName @lastName</div>
        <div class="user-role">Professor</div>
      </div>
    </div>
    <div class="sign-out-btn" onclick="window.location.href='@Url.Action("Logout", "Home")'">
      <div class="sign-out-icon"></div>
      <span class="sign-out-label">Sign Out</span>
    </div>
  </div>
</div>

<!-- MAIN CONTENT -->
<div class="main">

  <!-- DASHBOARD PAGE -->
  <div class="page active" id="page-dashboard">
    <div class="section-title">Welcome, Professor @firstName!</div>

    <div class="stat-cards">
      <div class="stat-card blue">
        <div class="stat-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#1c8aff" stroke-width="1.8"/>
            <circle cx="9" cy="7" r="4" stroke="#1c8aff" stroke-width="1.8"/>
          </svg>
        </div>
        <div>
          <div class="stat-value">0</div>
          <div class="stat-label">Total Students</div>
        </div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="#32b357" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M2 17l10 5 10-5" stroke="#32b357" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M2 12l10 5 10-5" stroke="#32b357" stroke-width="1.8" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <div class="stat-value">0</div>
          <div class="stat-label">Paid Fees</div>
        </div>
      </div>
      <div class="stat-card red">
        <div class="stat-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="#ff3b30" stroke-width="1.8"/>
            <path d="M12 8v4M12 16h.01" stroke="#ff3b30" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="stat-value">0</div>
          <div class="stat-label">Pending Fees</div>
        </div>
      </div>
    </div>

    <div class="content-card">
      <div class="card-title">Quick Actions</div>
      <p style="color: #666; margin-top: 12px;">View student payment status and generate reports from the sidebar menu.</p>
    </div>
  </div>

  <!-- STUDENTS PAGE -->
  <div class="page" id="page-students">
    <div class="section-title">My Students</div>
    <div class="content-card">
      <div class="table-header">
        <div class="search-box">
          <input type="text" class="search-input" placeholder="Search students...">
        </div>
      </div>
      <table class="data-table">
        <thead>
          <tr>
            <th>Student ID</th>
            <th>Name</th>
            <th>Course</th>
            <th>Year Level</th>
            <th>Payment Status</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="5" style="text-align: center; padding: 40px; color: #666;">No students assigned yet.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- REPORTS PAGE -->
  <div class="page" id="page-reports">
    <div class="section-title">Reports</div>
    <div class="content-card">
      <div class="card-title">Generate Reports</div>
      <p style="color: #666; margin-top: 12px;">Report generation features coming soon.</p>
    </div>
  </div>

  <!-- SETTINGS PAGE -->
  <div class="page" id="page-settings">
    <div class="section-title">Settings</div>
    <div class="content-card">
      <div class="card-title">Account Settings</div>
      <div style="margin-top: 16px;">
        <p><strong>Name:</strong> @firstName @lastName</p>
        <p><strong>School ID:</strong> @schoolId</p>
        <p><strong>Role:</strong> Professor</p>
      </div>
    </div>
  </div>

</div>

<script>
  // Page Navigation
  function showPage(pageName) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

    const page = document.getElementById('page-' + pageName);
    const nav = document.getElementById('nav-' + pageName);

    if (page) page.classList.add('active');
    if (nav) nav.classList.add('active');
  }

  // Mobile Sidebar Toggle
  function toggleSidebar() {
    document.body.classList.toggle('sidebar-open');
  }

  function closeSidebar() {
    document.body.classList.remove('sidebar-open');
  }

  // Close sidebar when clicking on nav items (mobile)
  document.querySelectorAll('.nav-item').forEach(item => {
    item.addEventListener('click', () => {
      if (window.innerWidth <= 768) {
        closeSidebar();
      }
    });
  });

  // Close sidebar on window resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      closeSidebar();
    }
  });

    // ── AUTH GUARD WITH OVERLAY ──────────────────────────────────
    const overlay = document.getElementById('auth-overlay');
    let isRedirecting = false; // ← guard flag prevents infinite loop

    function showDashboard() {
        if (!overlay) return;
        overlay.classList.add('fade-out');
        setTimeout(() => { if (overlay) overlay.remove(); }, 420);
    }

    function hardRedirectToLogin() {
        if (isRedirecting) return; // ← stop if already redirecting
        isRedirecting = true;
        window.location.replace('/');
    }

    function checkAuth() {
        if (isRedirecting) return; // ← stop if already redirecting
        fetch('/Home/CheckAuth?_=' + Date.now(), { cache: 'no-store' })
            .then(r => {
                if (!r.ok) throw new Error('CheckAuth endpoint not found: ' + r.status);
                return r.json();
            })
            .then(data => {
                if (data.authenticated) { showDashboard(); }
                else { hardRedirectToLogin(); }
            })
            .catch((err) => {
                console.error('Auth check failed:', err);
                hardRedirectToLogin();
            });
    }

    // Run on page load
    checkAuth();

    // Run when browser restores from bfcache (mobile swipe-back)
    window.addEventListener('pageshow', function (e) {
        if (e.persisted) {
            isRedirecting = false; // reset flag on fresh page show
            if (overlay) {
                overlay.style.opacity = '1';
                overlay.style.display = 'flex';
                overlay.classList.remove('fade-out');
            }
            checkAuth();
        }
    });

    // Run when tab becomes visible again
    document.addEventListener('visibilitychange', function () {
        if (!document.hidden && !isRedirecting) checkAuth();
    });

    // Trap back button
    history.pushState(null, '', window.location.href);
    window.addEventListener('popstate', function () {
        if (!isRedirecting) {
            checkAuth();
            history.pushState(null, '', window.location.href);
        }
    });
    // ────────────────────────────────────────────────────────────
</script>

</body>
</html>

