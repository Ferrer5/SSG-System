<!-- Expense Modal -->
<div class="modal-overlay" id="modal-expense">
  <div class="modal-backdrop" onclick="closeModal('modal-expense')"></div>
  <div class="modal-box">
    <div class="modal-hdr"><div><div class="modal-title">Record Expense</div><div class="modal-sub">Log an expenditure — maps to expenses table</div></div><button class="modal-close" onclick="closeModal('modal-expense')">✕</button></div>
    <div class="form-group"><label class="form-label">Description</label><input class="form-input" id="ex-desc" placeholder="e.g. Printing of event tarpaulins"/></div>
    <div class="form-grid">
      <div class="form-group"><label class="form-label">Amount (₱)</label><input class="form-input" id="ex-amount" type="number" placeholder="0.00"/></div>
      <div class="form-group"><label class="form-label">Date</label><input class="form-input" type="date" id="ex-date"/></div>
    </div>
    <div class="modal-footer"><button class="btn-outline" onclick="closeModal('modal-expense')">Cancel</button><button class="btn-primary" onclick="saveExpense()">Save Expense</button></div>
  </div>
</div>

<div id="toast"></div>

<script>
// ── CONFIG ──────────────────────────────────────────────────────
let REQ_FEE = 200; // Will be updated from current semester fee

// ── DATA STORE ───
let DB = {
  orgFees: [],
  funds: [],
  expenses: []
};

let STUDENTS = [];
let CURRENT_SCHOOL_YEAR = null;
let CURRENT_SEMESTER = null;

// ── STATE ────────────────────────────────────────────────────────
let histQ = '', histType = '', expQ = '';
let selStudent = null;
let barChart, donutChart;

// ── UTILS ────────────────────────────────────────────────────────
function p(n) { return '₱' + Number(n).toLocaleString('en-PH', { minimumFractionDigits: 2 }); }
function fd(d) { return new Date(d + 'T00:00').toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' }); }
function today() { return new Date().toISOString().split('T')[0]; }

async function loadDashboardData() {
  try {
    const res = await fetch('/Home/GetTreasurerDashboardStats');
    const data = await res.json();
    if (data.success) {
      CURRENT_SCHOOL_YEAR = data.schoolYear;
      CURRENT_SEMESTER = data.semester;

      // Update school year display
      const syDisplay = document.querySelector('.page-sub');
      if (syDisplay && CURRENT_SCHOOL_YEAR !== 'Not Set') {
        const semDisplay = CURRENT_SEMESTER !== 'Not Set' ? `${CURRENT_SEMESTER} Semester` : '';
        syDisplay.textContent = `A.Y. ${CURRENT_SCHOOL_YEAR}${semDisplay ? ' · ' + semDisplay : ''}`;
      }

      // Update stats
      document.getElementById('s-income').textContent = '₱' + Number(data.stats.totalIncome).toLocaleString('en-PH', { minimumFractionDigits: 2 });
      document.getElementById('s-expenses').textContent = '₱' + Number(data.stats.expensesTotal).toLocaleString('en-PH', { minimumFractionDigits: 2 });
      document.getElementById('s-balance').textContent = '₱' + Number(data.stats.balance).toLocaleString('en-PH', { minimumFractionDigits: 2 });

      const orgFeeTotal = data.stats.orgFeeTotal;
      const otherFundsTotal = data.stats.otherFundsTotal;
      document.getElementById('s-income-sub').textContent = 'Org Fees (₱' + Number(orgFeeTotal).toLocaleString('en-PH', { minimumFractionDigits: 2 }) + ') + Other Funds (₱' + Number(otherFundsTotal).toLocaleString('en-PH', { minimumFractionDigits: 2 }) + ')';
      document.getElementById('s-exp-sub').textContent = data.stats.expenseCount + ' expense record' + (data.stats.expenseCount !== 1 ? 's' : '');

      const bal = data.stats.balance;
      const balEl = document.getElementById('s-balance-sub');
      balEl.textContent = bal >= 0 ? 'Surplus — ₱' + Number(bal).toLocaleString('en-PH', { minimumFractionDigits: 2 }) + ' available' : 'Deficit — ₱' + Number(Math.abs(bal)).toLocaleString('en-PH', { minimumFractionDigits: 2 }) + ' over budget';
      balEl.style.color = bal >= 0 ? 'rgba(95,221,142,.8)' : 'rgba(248,113,113,.8)';

      // Update recent transactions
      const tbody = document.getElementById('dash-tbody');
      if (data.recentTransactions.length > 0) {
        tbody.innerHTML = data.recentTransactions.map(t => `
          <tr>
            <td class="td-mono td-m">${fd(t.date)}</td>
            <td><strong>${t.description}</strong></td>
            <td><span class="badge ${t.type==='income'?'bg':'br'}">${t.type === 'income' ? 'Income' : 'Expense'}</span></td>
            <td class="${t.type==='income'?'amt-in':'amt-out'}">${t.type==='income'?'+':'-'}₱${Number(t.amount).toLocaleString('en-PH', { minimumFractionDigits: 2 })}</td>
          </tr>
        `).join('');
      } else {
        tbody.innerHTML = '<tr class="empty-row"><td colspan="4">No transactions yet.</td></tr>';
      }
    }
  } catch (err) {
    console.error('Failed to load dashboard data:', err);
  }
}

async function loadOrgFeePayments() {
  try {
    const res = await fetch('/Home/GetOrgFeePayments');
    const data = await res.json();
    if (data.success) {
      DB.orgFees = data.payments.map(p => ({
        id: p.paymentId,
        userId: p.userId,
        name: p.studentName,
        schoolId: p.schoolId,
        course: p.courseCode,
        yr: p.yearSection,
        sem: p.semester,
        amt: p.amount,
        status: p.paymentStatus,
        receipt: p.receiptNumber || '',
        date: p.paymentDate.split('T')[0]
      }));
    }
  } catch (err) {
    console.error('Failed to load org fee payments:', err);
  }
}

async function loadOtherFunds() {
  try {
    const res = await fetch('/Home/GetOtherFunds');
    const data = await res.json();
    if (data.success) {
      DB.funds = data.funds.map(f => ({
        id: f.fundId,
        source: f.source,
        desc: f.description,
        cat: 'Other Fund',
        amt: f.amount,
        date: f.receivedDate.split('T')[0]
      }));
    }
  } catch (err) {
    console.error('Failed to load other funds:', err);
  }
}

async function loadExpenses() {
  try {
    const res = await fetch('/Home/GetExpenses');
    const data = await res.json();
    if (data.success) {
      DB.expenses = data.expenses.map(e => ({
        id: e.expenseId,
        desc: e.description,
        amt: e.amount,
        date: e.expenseDate.split('T')[0],
        recordedBy: e.recordedBy
      }));
    }
  } catch (err) {
    console.error('Failed to load expenses:', err);
  }
}

async function loadStudents() {
  try {
    const res = await fetch('/Home/GetStudentsForPayment');
    const data = await res.json();
    if (data.success) {
      STUDENTS = data.students.map(s => ({
        userId: s.userId,
        schoolId: s.schoolId,
        name: s.name,
        course: s.courseCode,
        yr: s.yearSection,
        hasPaid: s.hasPaid
      }));
    }
  } catch (err) {
    console.error('Failed to load students:', err);
  }
}

async function loadCurrentSemesterInfo() {
  try {
    const res = await fetch('/Home/GetCurrentSchoolYearAndSemester');
    const data = await res.json();
    if (data.success) {
      CURRENT_SCHOOL_YEAR = data.schoolYear;
      CURRENT_SEMESTER = data.semester;
      if (data.semester) {
        REQ_FEE = data.semester.amount;
      }

      // Update school year display
      const syDisplay = document.querySelector('#page-dashboard .page-sub');
      if (syDisplay && CURRENT_SCHOOL_YEAR) {
        const semDisplay = CURRENT_SEMESTER ? `${CURRENT_SEMESTER.semester === 'First' ? '1st' : '2nd'} Semester` : '';
        syDisplay.textContent = `A.Y. ${CURRENT_SCHOOL_YEAR.yearStart}–${CURRENT_SCHOOL_YEAR.yearEnd}${semDisplay ? ' · ' + semDisplay : ''}`;
      }

      // Update fee amount display on Income card
      const feeDisplay = document.getElementById('current-fee-amount');
      if (feeDisplay && data.semester) {
        feeDisplay.textContent = '₱' + Number(data.semester.amount).toFixed(2);
      }

      // Update modal subtitle
      const modalSub = document.getElementById('org-fee-modal-sub');
      if (modalSub && data.semester) {
        modalSub.textContent = `Student SSG membership fee — Current: ₱${Number(data.semester.amount).toFixed(2)}`;
      }
    }
  } catch (err) {
    console.error('Failed to load semester info:', err);
  }
}

function allTransactions() {
  let rows = [];
  DB.orgFees.forEach(x => rows.push({ type:'income', cat:'Org Fee', desc:'Org Fee – ' + x.name + ' (' + x.course + ' ' + x.yr + ')', amt:x.amt, date:x.date, receipt:x.receipt||'—', src:'OrgFee', sid:x.id }));
  DB.funds.forEach(x   => rows.push({ type:'income', cat:'Other Receivable', desc:x.desc + (x.source ? ' – from ' + x.source : ''), amt:x.amt, date:x.date, receipt:'—', src:'OtherFund', sid:x.id }));
  DB.expenses.forEach(x=> rows.push({ type:'expense', cat:'Expense', desc:x.desc, amt:x.amt, date:x.date, receipt:'—', src:'Expense', sid:x.id }));
  return rows.sort((a, b) => b.date.localeCompare(a.date));
}

function totalIncome()   { return DB.orgFees.reduce((s,x)=>s+x.amt,0) + DB.funds.reduce((s,x)=>s+x.amt,0); }
function totalExpenses() { return DB.expenses.reduce((s,x)=>s+x.amt,0); }

// ── PAGE NAVIGATION ──────────────────────────────────────────────
async function showPage(name, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  if (el) el.classList.add('active');
  if (name === 'dashboard') { await renderDashboard(); setTimeout(renderCharts, 100); }
  if (name === 'history')   await renderHistory();
  if (name === 'income')    await renderIncome();
  if (name === 'expenses')  await renderExpenses();
  if (name === 'settings')  await refreshSchoolYears();
}

// ── DASHBOARD ────────────────────────────────────────────────────
async function renderDashboard() {
  await loadDashboardData();

  let inc = totalIncome(), exp = totalExpenses(), bal = inc - exp;
  let orgT = DB.orgFees.reduce((s,x)=>s+x.amt,0);
  let funT = DB.funds.reduce((s,x)=>s+x.amt,0);

  document.getElementById('s-income-sub').textContent = 'Org Fees (' + p(orgT) + ') + Other Funds (' + p(funT) + ')';
  document.getElementById('s-exp-sub').textContent    = DB.expenses.length + ' expense record' + (DB.expenses.length !== 1 ? 's' : '');

  let balEl = document.getElementById('s-balance-sub');
  balEl.textContent = bal >= 0 ? 'Surplus — ' + p(bal) + ' available' : 'Deficit — ' + p(Math.abs(bal)) + ' over budget';
  balEl.style.color = bal >= 0 ? 'rgba(95,221,142,.8)' : 'rgba(248,113,113,.8)';
}

function renderCharts() {
  let months = ['Jan','Feb','Mar','Apr','May','Jun'];
  let mInc = [0,0,0,0,0,0], mExp = [0,0,0,0,0,0];
  allTransactions().forEach(t => {
    let m = new Date(t.date + 'T00:00').getMonth();
    if (m < 6) { if (t.type==='income') mInc[m]+=t.amt; else mExp[m]+=t.amt; }
  });

  let mode = document.getElementById('chart-mode').value;
  let datasets = [];
  if (mode==='both'||mode==='income')  datasets.push({ label:'Income',   data:mInc, backgroundColor:'rgba(39,167,68,.75)',  borderRadius:4, borderSkipped:false });
  if (mode==='both'||mode==='expense') datasets.push({ label:'Expenses', data:mExp, backgroundColor:'rgba(239,68,68,.65)', borderRadius:4, borderSkipped:false });

  if (barChart) barChart.destroy();
  barChart = new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: { labels: months, datasets },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins: {
        legend: { display: datasets.length > 1, labels: { color:'rgba(232,245,236,.5)', font:{size:11}, boxWidth:10, padding:12 } },
        tooltip: { callbacks: { label: ctx => ' ' + p(ctx.parsed.y) } }
      },
      scales: {
        x: { grid:{display:false}, ticks:{color:'rgba(232,245,236,.4)',font:{size:10}} },
        y: { grid:{color:'rgba(255,255,255,.05)'}, ticks:{color:'rgba(232,245,236,.4)',font:{size:10},callback:v=>'₱'+v.toLocaleString()} }
      }
    }
  });

  let orgT = DB.orgFees.reduce((s,x)=>s+x.amt,0);
  let funT = DB.funds.reduce((s,x)=>s+x.amt,0);
  let expT = totalExpenses();
  let dLabels = ['Org Fees','Other Funds','Expenses'];
  let dData   = [orgT, funT, expT];
  let dColors = ['rgba(39,167,68,.8)','rgba(59,130,246,.8)','rgba(239,68,68,.7)'];
  let valColors = ['#5fdd8e','#93c5fd','#f87171'];

  if (donutChart) donutChart.destroy();
  donutChart = new Chart(document.getElementById('donutChart'), {
    type: 'doughnut',
    data: { labels:dLabels, datasets:[{ data:dData, backgroundColor:dColors, borderWidth:0, hoverOffset:4 }] },
    options: { responsive:true, cutout:'68%', plugins:{ legend:{display:false}, tooltip:{callbacks:{label:ctx=>` ${p(ctx.parsed)}`}} } }
  });

  let total = orgT + funT + expT;
  document.getElementById('donut-legend').innerHTML = dLabels.map((l,i) => `
    <div class="dl-row">
      <div class="dl-lbl"><div class="dl-dot" style="background:${dColors[i]}"></div>${l}</div>
      <div class="dl-val" style="color:${valColors[i]}">${total>0?Math.round(dData[i]/total*100):0}% · ${p(dData[i])}</div>
    </div>`).join('');
}

function updateCharts() { renderCharts(); }

// ── HISTORY ──────────────────────────────────────────────────────
async function renderHistory() {
  await loadOrgFeePayments();
  await loadOtherFunds();
  await loadExpenses();

  let tx = allTransactions().filter(t =>
    (!histQ || t.desc.toLowerCase().includes(histQ.toLowerCase())) &&
    (!histType || t.type === histType));
  let inc = tx.filter(t=>t.type==='income').reduce((s,t)=>s+t.amt,0);
  let exp = tx.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amt,0);
  let bal = inc - exp;
  document.getElementById('h-income').textContent  = '+' + p(inc);
  document.getElementById('h-expense').textContent = '-' + p(exp);
  let balEl = document.getElementById('h-balance');
  balEl.textContent = (bal>=0?'+':'') + p(bal);
  balEl.className = 'summary-val ' + (bal>=0?'amt-in':'amt-out');
  document.getElementById('history-tbody').innerHTML = tx.map(t => `
    <tr>
      <td class="td-mono td-m">${fd(t.date)}</td>
      <td><strong>${t.desc}</strong></td>
      <td><span class="badge ${t.type==='income'?'bg':'br'}">${t.cat}</span></td>
      <td><span class="badge ${t.type==='income'?'bg':'br'}">${t.type==='income'?'Income':'Expense'}</span></td>
      <td class="td-mono td-m">${t.receipt}</td>
      <td class="${t.type==='income'?'amt-in':'amt-out'}">${t.type==='income'?'+':'-'}${p(t.amt)}</td>
