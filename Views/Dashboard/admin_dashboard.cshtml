<div id="toast"></div>

<script>
function showPage(name, navEl) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    var page = document.getElementById('page-' + name);
    if (page) page.classList.add('active');
    if (navEl) navEl.classList.add('active');
    else { var n = document.getElementById('nav-' + name); if (n) n.classList.add('active'); }

    // refresh the tab data
    if (name === 'dashboard')   refreshDashboard();
    if (name === 'requests')    refreshRequests();
    if (name === 'rejected')    refreshRejected();
    if (name === 'students')    refreshStudents();
    if (name === 'professors')  refreshProfessors();
}
async function updateStatus(accountId, status) {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    if (!confirm(`Are you sure you want to ${status.toLowerCase()} this account?`)) return;
    try {
        const res  = await fetch('/Home/UpdateAccountStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body: JSON.stringify({ accountId, status })
        });
        const data = await res.json();
        if (data.success) {
            const row = document.getElementById(`req-row-${accountId}`);
            if (row) { row.style.opacity = '0'; row.style.transition = 'opacity .3s'; setTimeout(() => row.remove(), 300); }
            const badge = document.querySelector('.nav-badge');
            if (badge) { const count = parseInt(badge.textContent) - 1; if (count <= 0) badge.remove(); else badge.textContent = count; }
            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }
}

async function deleteRejected(accountId) {
    if (!confirm('Are you sure you want to permanently delete this account? This cannot be undone.')) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    try {
        const res = await fetch('/Home/DeleteAccount', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ?? ''
            },
            body: JSON.stringify({ accountId: accountId })
        });
        const data = await res.json();

        if (data.success) {
            const row = document.getElementById('rej-row-' + accountId);
            if (row) {
                row.style.opacity = '0';
                row.style.transition = 'opacity 0.3s';
                setTimeout(() => row.remove(), 300);
            }
            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }
}

function filterTable(input,tbodyId){
  var q=input.value.toLowerCase();
  document.querySelectorAll('#'+tbodyId+' tr').forEach(function(row){
    row.style.display=row.textContent.toLowerCase().includes(q)?'':'none';
  });
}
function showToast(msg,type){
  var t=document.getElementById('toast');
  t.textContent=msg;t.className='show '+type;
  clearTimeout(t._t);t._t=setTimeout(()=>t.className='',3000);
}
function showAddProfessorModal(){
  showToast('Add Professor feature coming soon!', 'ok');
}
function toggleRecentRows() {
    var rows = document.querySelectorAll('.recent-row');
    var btn = document.getElementById('view-all-btn');
    var isExpanded = btn.getAttribute('data-expanded') === 'true';
    
    rows.forEach(function(row, i) {
        if (i >= 5) {
            row.style.display = isExpanded ? 'none' : '';
        }
    });
    
    btn.setAttribute('data-expanded', isExpanded ? 'false' : 'true');
    var total = btn.getAttribute('data-total');
    btn.textContent = isExpanded ? 'View All (' + total + ')' : 'Show Less';
}
function toggleDropdown(btn) {
    // close all other open dropdowns first
    document.querySelectorAll('.dropdown-menu.open').forEach(function(m) {
        if (m !== btn.nextElementSibling) m.classList.remove('open');
    });
    btn.nextElementSibling.classList.toggle('open');
}

// close dropdown when clicking outside
document.addEventListener('click', function(e) {
    if (!e.target.closest('.dropdown-wrap')) {
        document.querySelectorAll('.dropdown-menu.open').forEach(function(m) {
            m.classList.remove('open');
        });
    }
});

// holds courses list so we only fetch once
let coursesCache = [];

let emailCheckTimer = null;
let emailIsTaken = false;

function checkEmailAvailability(value) {
    const feedback = document.getElementById('email-feedback');
    const input = document.getElementById('edit-email');
    const accountId = parseInt(document.getElementById('edit-accountId').value);

    clearTimeout(emailCheckTimer);

    if (!value || !value.includes('@@')) {
        feedback.textContent = '';
        input.style.borderColor = 'rgba(255,255,255,0.12)';
        return;
    }

    emailCheckTimer = setTimeout(async () => {
        try {
            const res = await fetch('/Home/CheckEmail?email=' + encodeURIComponent(value) + '&excludeAccountId=' + accountId);
            const data = await res.json();

            if (data.taken) {
                emailIsTaken = true;
                feedback.textContent = 'This email is already used by ' + data.usedBy;
                feedback.style.color = '#f87171';
                input.style.borderColor = 'rgba(239,68,68,0.5)';
            } else {
                emailIsTaken = false;
                feedback.textContent = 'Email is available';
                feedback.style.color = '#5fdd8e';
                input.style.borderColor = 'rgba(39,167,68,0.5)';
            }
        } catch {
            feedback.textContent = '';
        }
    }, 500); // debounce — waits 500ms after user stops typing
}

async function loadCoursesIntoSelect() {
    if (coursesCache.length > 0) return; // already loaded
    try {
        const res  = await fetch('/Home/GetCourses');
        const data = await res.json();
        if (data.success) {
            coursesCache = data.courses;
            const sel = document.getElementById('edit-courseId');
            sel.innerHTML = '<option value="">Select course</option>';
            data.courses.forEach(c => {
                const opt = document.createElement('option');
                opt.value       = c.courseId;
                opt.textContent = c.courseCode;
                sel.appendChild(opt);
            });
        }
    } catch { showToast('Failed to load courses.', 'fail'); }
}

async function editStudent(accountId) {
    document.getElementById('editModal').style.display = 'flex';
    document.getElementById('edit-accountId').value = accountId;

    // load courses first
    await loadCoursesIntoSelect();

    // fetch current student data
    try {
        const res  = await fetch(`/Home/GetStudent?accountId=${accountId}`);
        const data = await res.json();
        if (data.success) {
            document.getElementById('edit-firstName').value  = data.firstName  ?? '';
            document.getElementById('edit-lastName').value   = data.lastName   ?? '';
            document.getElementById('edit-middleName').value = data.middleName ?? '';
            document.getElementById('edit-email').value     = data.email     ?? '';
            document.getElementById('edit-courseId').value   = data.courseId   ?? '';
            document.getElementById('edit-yearLevel').value  = data.yearLevel  ?? '1';
            document.getElementById('edit-section').value    = data.section    ?? '';
        } else {
            showToast(data.message, 'fail');
            closeEditModal();
        }
    } catch { showToast('Failed to load student.', 'fail'); closeEditModal(); }
}

function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
    emailIsTaken = false;
    document.getElementById('email-feedback').textContent = '';
}

async function saveStudent() {
    const accountId  = parseInt(document.getElementById('edit-accountId').value);
    const firstName  = document.getElementById('edit-firstName').value.trim();
    const lastName   = document.getElementById('edit-lastName').value.trim();
    const middleName = document.getElementById('edit-middleName').value.trim();
    const email      = document.getElementById('edit-email').value.trim();
    const courseId   = parseInt(document.getElementById('edit-courseId').value);
    const yearLevel  = parseInt(document.getElementById('edit-yearLevel').value);
    const section    = document.getElementById('edit-section').value.trim();

    if (!firstName || !lastName) { showToast('First and last name are required.', 'fail'); return; }
    if (!courseId)                { showToast('Please select a course.', 'fail'); return; }

    if (emailIsTaken) {
        showToast('Please use a different email address.', 'fail');
        return;
    }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    try {
        const res  = await fetch('/Home/UpdateStudent', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body:    JSON.stringify({ accountId, firstName, lastName, middleName, email, courseId, yearLevel, section })
        });
        const data = await res.json();

        if (data.success) {
            // update the row in the DOM without reload
            const row       = document.querySelector(`[data-account="${accountId}"]`);
            const nameCell  = row?.querySelector('td:nth-child(2)');
            const courseCell = row?.querySelector('td:nth-child(3)');
            const yearCell  = row?.querySelector('td:nth-child(4)');

            if (nameCell) {
                const isActive = row.getAttribute('data-active') === 'true';
                const fullName = `${lastName.toUpperCase()}, ${firstName.toUpperCase()}`;
                nameCell.innerHTML = isActive
                    ? `<strong>${fullName}</strong>` 
                    : `<strong style="color:#f87171">${fullName}</strong>
                       <span class="deactivated-badge" style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:8px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle;">Deactivated</span>`;
            }
            if (courseCell) {
                const courseName = coursesCache.find(c => c.courseId === courseId)?.courseCode ?? '';
                courseCell.innerHTML = `<span class="badge bg">${courseName}</span>`;
            }
            if (yearCell) {
                yearCell.textContent = `${yearLevel}-${section}`;
            }

            closeEditModal();
            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch { showToast('Save failed. Please try again.', 'fail'); }
}
async function deleteStudent(accountId) {
    if (!confirm('Are you sure you want to PERMANENTLY delete this account? This cannot be undone.')) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        const res = await fetch('/Home/DeleteAccount', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body: JSON.stringify({ accountId: accountId })
        });
        const data = await res.json();
        if (data.success) {
            // remove the row from DOM instantly
            const row = document.querySelector(`[data-account="${accountId}"]`);
            if (row) { row.style.opacity = '0'; row.style.transition = 'opacity .3s'; setTimeout(() => row.remove(), 300); }
            showToast(data.message, 'ok');
            // NO redirect here
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }
}

async function toggleActivation(accountId, el) {
    const row = document.querySelector(`[data-account="${accountId}"]`);
    const isActive = row.getAttribute('data-active') === 'true';
    const action = isActive ? 'deactivate' : 'reactivate';

    if (!confirm(`Are you sure you want to ${action} this account?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    try {
        const res = await fetch('/Home/ToggleAccountActivation', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ?? ''
            },
            body: JSON.stringify({ accountId: accountId })
        });

        const data = await res.json();

        if (data.success) {
            row.setAttribute('data-active', data.isActive.toString());

            // update button text and color
            const span = el.querySelector('span');
            if (span) span.textContent = data.isActive ? 'Deactivate Account' : 'Reactivate Account';
            el.classList.remove('danger', 'reactivate');
            el.classList.add(data.isActive ? 'danger' : 'reactivate');

            // update the name cell — add/remove red color and badge
            const nameCell = row.querySelector('td:nth-child(2)');
            if (nameCell) {
                const strong = nameCell.querySelector('strong');
                const nameText = strong ? strong.textContent : '';

                if (!data.isActive) {
                    // deactivated → red + badge
                    nameCell.innerHTML = `
                        <strong style="color:#f87171">${nameText}</strong>
                        <span class="deactivated-badge" style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:8px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle;">Deactivated</span>
                    `;
                    row.style.opacity = '0.45';
                } else {
                    // reactivated → back to normal
                    nameCell.innerHTML = `<strong>${nameText}</strong>`;
                    row.style.opacity = '1';
                }
            }

            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }

    // close the dropdown
    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
}

function showRoleSubmenu(el, accountId) {
    event.stopPropagation();
    document.querySelectorAll('[id^="role-submenu-"]').forEach(function(s) {
        if (s.id !== 'role-submenu-' + accountId) s.style.display = 'none';
    });
    var submenu = document.getElementById('role-submenu-' + accountId);
    if (submenu) {
        submenu.style.display = submenu.style.display === 'block' ? 'none' : 'block';
        submenu.classList.add('open');
    }
}

async function changeRole(accountId, role) {
    if (!confirm('Change this account role to ' + role + '?')) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    try {
        const res = await fetch('/Home/ChangeRole', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ?? ''
            },
            body: JSON.stringify({ accountId: accountId, role: role })
        });
        const data = await res.json();

        if (data.success) {
            showToast(data.message, 'ok');
            // just close dropdown, don't remove the row
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }

    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
    document.querySelectorAll('[id^="role-submenu-"]').forEach(s => s.style.display = 'none');
}

async function refreshDashboard() {
    try {
        const res  = await fetch('/Home/GetDashboardStats');
        const data = await res.json();
        if (!data.success) return;

        // update stat cards
        const statVals = document.querySelectorAll('#page-dashboard .stat-val');
        if (statVals[0]) statVals[0].textContent = data.approvedCount;
        if (statVals[1]) statVals[1].textContent = data.pendingCount;
        if (statVals[2]) statVals[2].textContent = data.studentCount;
        if (statVals[3]) statVals[3].textContent = data.treasurerCount;
        if (statVals[4]) statVals[4].textContent = data.professorCount;
        if (statVals[5]) statVals[5].textContent = data.adminCount;

        // update pending requests subtitle
        const pendingTrend = document.querySelector('#page-dashboard .stat-trend.warn, #page-dashboard .stat-trend');
        if (pendingTrend) {
            pendingTrend.textContent = data.pendingCount === 0 ? 'No pending requests' : 'Awaiting review';
            pendingTrend.className   = 'stat-trend' + (data.pendingCount > 0 ? ' warn' : '');
        }

        // update nav badge
        const badge = document.querySelector('#nav-requests .nav-badge');
        if (data.pendingCount > 0) {
            if (badge) badge.textContent = data.pendingCount;
            else {
                const navReq = document.getElementById('nav-requests');
                if (navReq) {
                    const b = document.createElement('span');
                    b.className   = 'nav-badge';
                    b.textContent = data.pendingCount;
                    navReq.appendChild(b);
                }
            }
        } else {
            if (badge) badge.remove();
        }

        // refresh recent requests table
        const tbody = document.getElementById('recent-tbody');
        if (tbody && data.recentRequests) {
            if (data.recentRequests.length === 0) {
                tbody.innerHTML = '<tr class="empty-row"><td colspan="6">No account requests found.</td></tr>';
            } else {
                tbody.innerHTML = data.recentRequests.slice(0, 5).map(r => `
                    <tr class="recent-row">
                        <td class="td-mono td-m">${r.schoolId ?? '—'}</td>
                        <td><strong>${r.fullname}</strong></td>
                        <td class="td-m">${r.courseCode ?? '—'}</td>
                        <td class="td-m">${r.yearLevel ?? '—'}-${r.section ?? '—'}</td>
                        <td class="td-mono td-m">${r.createdAt}</td>
                        <td><span class="badge ${r.status === 'Approved' ? 'bg' : r.status === 'Rejected' ? 'br' : 'by'}">${r.status}</span></td>
                    </tr>
                `).join('');
            }
        }

    } catch {}
}

