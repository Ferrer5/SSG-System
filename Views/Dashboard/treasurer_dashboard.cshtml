    if (data.schoolYears.length === 0) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="5">No school years found.</td></tr>';
      return;
    }

    tbody.innerHTML = data.schoolYears.map((sy, i) => `
      <tr>
        <td class="td-mono td-m">${i + 1}</td>
        <td><strong>${sy.yearStart} – ${sy.yearEnd}</strong></td>
        <td>
          ${sy.hasFirst  ? '<span class="badge bg" style="margin-right:4px">1st</span>' : '<span class="badge" style="background:rgba(255,255,255,.05);color:var(--text-d);margin-right:4px">1st</span>'}
          ${sy.hasSecond ? '<span class="badge bg">2nd</span>'                           : '<span class="badge" style="background:rgba(255,255,255,.05);color:var(--text-d)">2nd</span>'}
        </td>
