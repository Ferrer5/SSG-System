<!-- Antiforgery token -->
@Html.AntiForgeryToken()

<div id="toast"></div>

<script>
    // ── Page switching ────────────────────────────────────────────
    function showPage(name) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        const page = document.getElementById('page-' + name);
        const nav  = document.getElementById('nav-' + name);
        if (page) page.classList.add('active');
        if (nav)  nav.classList.add('active');
        window.scrollTo(0, 0);
    }

    // ── Approve / Reject ──────────────────────────────────────────
    async function updateStatus(accountId, status) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        if (!confirm(`Are you sure you want to ${status.toLowerCase()} this account?`)) return;

        try {
            const res  = await fetch('/Home/UpdateAccountStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token ?? ''
                },
                body: JSON.stringify({ accountId, status })
            });
            const data = await res.json();

            if (data.success) {
                // Remove row from requests page
                const row = document.getElementById(`req-row-${accountId}`);
                if (row) { 
                    row.style.opacity = '0'; 
                    row.style.transition = 'opacity .3s'; 
                    setTimeout(() => row.remove(), 300); 
                }
                // Update badge count
                const badge = document.querySelector('.nav-badge');
                if (badge) {
                    const count = parseInt(badge.textContent) - 1;
                    if (count <= 0) badge.remove(); else badge.textContent = count;
                }
                // Update stat card
                const statVal = document.querySelector('.stat-value');
                if (statVal) {
                    const cur = parseInt(statVal.textContent) || 0;
                    statVal.textContent = Math.max(0, cur - 1);
                }
                showToast(data.message, 'ok');
            } else {
                showToast(data.message, 'fail');
            }
        } catch (err) {
            showToast('Request failed. Please try again.', 'fail');
        }
    }

    // ── Student search ────────────────────────────────────────────
    function filterStudents() {
        const q = document.getElementById('student-search').value.toLowerCase();
        document.querySelectorAll('#students-tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    // ── Admin search ────────────────────────────────────────────
    function filterAdmins() {
        const q = document.getElementById('admin-search').value.toLowerCase();
        document.querySelectorAll('#admins-tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    // ── Treasurer search ────────────────────────────────────────────
    function filterTreasurers() {
        const q = document.getElementById('treasurer-search').value.toLowerCase();
        document.querySelectorAll('#treasurers-tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    // ── Professor search ────────────────────────────────────────────
    function filterProfessors() {
        const q = document.getElementById('professor-search').value.toLowerCase();
        document.querySelectorAll('#professors-tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    // ── Toast ─────────────────────────────────────────────────────
    function showToast(msg, type) {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.className = `show ${type}`;
        clearTimeout(t._t);
        t._t = setTimeout(() => t.className = '', 3500);
    }
</script>
</body>
</html>
