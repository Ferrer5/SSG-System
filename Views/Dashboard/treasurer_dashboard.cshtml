async function renderIncome() {
  await loadOrgFeePayments();
  await loadOtherFunds();

  let rows = [
    ...DB.orgFees.map(x=>({ type:'OrgFee',    id:x.id, date:x.date, desc:'Org Fee – '+x.name+' ('+x.course+' '+x.yr+')', cat:'Org Fee',         amt:x.amt, receipt:x.receipt||'—' })),
