@model MyMvcApp.Models.DashboardViewModel
@{
    Layout = null;
    var firstName = Context.Session.GetString("FirstName") ?? "Admin";
    var lastName  = Context.Session.GetString("LastName") ?? "";
    var schoolId  = Context.Session.GetString("SchoolId") ?? "";
    var initials  = (firstName.Length > 0 ? firstName[0].ToString() : "") + (lastName.Length > 0 ? lastName[0].ToString() : "");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSG Finance — Admin Panel</title>
    <link rel="icon" type="image/png" href="~/favicon.png">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Mono:wght@400;500&display=swap');

        *{box-sizing:border-box;margin:0;padding:0}
        :root{
          --bg:#071a0c;
          --bg2:#0c2413;
          --sidebar:#081509;
          --green:#27a744;
          --green-d:#1a7a4a;
          --green-glow:rgba(39,167,68,.18);
          --green-glow2:rgba(39,167,68,.08);
          --glass:rgba(255,255,255,.045);
          --glass-b:rgba(255,255,255,.09);
          --text:#e8f5ec;
          --text-m:rgba(232,245,236,.6);
          --text-d:rgba(232,245,236,.35);
          --card:#0f2918;
          --card-b:rgba(255,255,255,.07);
          --green-badge:rgba(39,167,68,.18);
          --green-badge-t:#5fdd8e;
          --yellow-badge:rgba(251,191,36,.14);
          --yellow-badge-t:#fbbf24;
          --red-badge:rgba(239,68,68,.14);
          --red-badge-t:#f87171;
        }
        body{font-family:'DM Sans',sans-serif;background:var(--bg);display:flex;min-height:100vh;color:var(--text);font-size:14px;width:100%;overflow:hidden}
        .sidebar{width:210px;background:var(--sidebar);border-right:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;flex-shrink:0}
        .sb-brand{display:flex;align-items:center;gap:10px;padding:20px 16px 18px;border-bottom:1px solid rgba(255,255,255,.05)}
        .sb-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 14px rgba(39,167,68,.3)}
        .sb-logo svg{width:18px;height:18px}
        .sb-brand-name{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}
        .sb-brand-sub{font-size:10px;color:rgba(39,167,68,.85);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
        .sb-label{font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-d);padding:16px 16px 5px}
        .nav-item{display:flex;align-items:center;gap:9px;padding:8px 12px;margin:1px 8px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;text-decoration:none;position:relative}
        .nav-item:hover{background:var(--glass);color:var(--text)}
        .nav-item.active{background:var(--green-glow);color:#5fdd8e;border:1px solid rgba(74,222,128,.12)}
        .nav-item svg{width:15px;height:15px;flex-shrink:0;opacity:.85}
        .nav-badge{margin-left:auto;background:#dc2626;color:#fff;font-size:9px;font-weight:700;min-width:17px;height:17px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 5px}
        .sb-spacer{flex:1}
        .sb-user{padding:10px 8px 10px;border-top:1px solid rgba(255,255,255,.05)}
        .user-card{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:var(--glass)}
        .user-av{width:30px;height:30px;border-radius:7px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
        .user-name{font-size:12px;font-weight:600;color:#fff}
        .user-role{font-size:10.5px;color:var(--text-d)}
        .signout{display:flex;align-items:center;gap:7px;padding:7px 10px;margin-top:3px;border-radius:8px;font-size:12.5px;font-weight:500;color:var(--text-d);cursor:pointer;transition:all .15s}
        .signout:hover{background:rgba(239,68,68,.08);color:#f87171}
        .signout svg{width:14px;height:14px}

        .main{margin-left:0;flex:1;min-width:0;padding:36px 36px 60px;background:var(--bg);overflow-y:auto;overflow-x:hidden;position:relative;height:100vh}
        .main::before{content:'';position:absolute;top:-80px;right:-80px;width:380px;height:380px;background:radial-gradient(circle,rgba(39,167,68,.06) 0%,transparent 70%);pointer-events:none;border-radius:50%}

        .page{display:none}.page.active{display:block}

        .page-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
        .page-title{font-size:22px;font-weight:800;color:#fff;letter-spacing:-.03em}
        .page-sub{font-size:12px;color:var(--text-m);margin-top:2px}

        .stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px;width:100%}
        .stat-col{display:flex;flex-direction:column;gap:12px}
        .stat-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:18px 20px;display:flex;flex-direction:column;gap:8px;position:relative;overflow:hidden;backdrop-filter:blur(8px)}
        .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.25),transparent)}
        .stat-card-half{flex:1;padding:13px 16px;gap:5px}
        .stat-card-half .stat-val{font-size:26px}
        .stat-lbl{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d)}
        .stat-row{display:flex;align-items:center;justify-content:space-between}
        .stat-val{font-size:34px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em}
        .stat-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
        .stat-icon.g{background:rgba(39,167,68,.15)}
        .stat-icon.y{background:rgba(251,191,36,.12)}
        .stat-icon svg{width:15px;height:15px}
        .stat-trend{font-size:11px;font-weight:500;color:var(--green)}
        .stat-trend.warn{color:#fbbf24}

        .content-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;overflow:visible;margin-bottom:16px;backdrop-filter:blur(8px);position:relative;width:100%;isolation:isolate}
        .content-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent);z-index:1}
        .cc-hdr{display:flex;align-items:center;justify-content:space-between;padding:15px 20px 13px;border-bottom:1px solid rgba(255,255,255,.05)}
        .cc-title{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}

        .toolbar{display:flex;align-items:center;justify-content:space-between;padding:13px 20px;border-bottom:1px solid rgba(255,255,255,.05)}
        .search-box{display:flex;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 12px;font-size:12.5px;color:var(--text-m);background:rgba(255,255,255,.04);min-width:220px;transition:all .15s}
        .search-box:focus-within{border-color:var(--green);background:rgba(39,167,68,.06);box-shadow:0 0 0 3px var(--green-glow2)}
        .search-box input{border:none;outline:none;font-family:inherit;font-size:12.5px;color:var(--text);width:100%;background:transparent}
        .search-box input::placeholder{color:var(--text-d)}
        .search-box svg{width:14px;height:14px;color:var(--text-d);flex-shrink:0}

        .tbl-wrap{overflow-x:visible}
        table{width:100%;border-collapse:collapse;font-size:12.5px}
        thead th{padding:10px 15px;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);border-bottom:1px solid rgba(255,255,255,.05);text-align:left;white-space:nowrap;background:rgba(255,255,255,.02)}
        tbody tr{border-bottom:1px solid rgba(255,255,255,.04);transition:background .1s}
        tbody tr:last-child{border-bottom:none}
        tbody tr:hover{background:rgba(39,167,68,.05)}
        td{padding:11px 15px;color:var(--text);vertical-align:middle}
        .td-m{color:var(--text-m)}
        .td-mono{font-family:'DM Mono',monospace;font-size:11.5px}

        .badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:600;letter-spacing:.02em}
        .bg{background:var(--green-badge);color:var(--green-badge-t)}
        .by{background:var(--yellow-badge);color:var(--yellow-badge-t)}
        .br{background:var(--red-badge);color:var(--red-badge-t)}

        .action-btns{display:flex;align-items:center;gap:6px}
        .btn-ap,.btn-rj{display:inline-flex;align-items:center;gap:4px;padding:5px 12px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid transparent;transition:all .15s;font-family:inherit;white-space:nowrap}
        .btn-ap{background:var(--green-badge);color:var(--green-badge-t);border-color:rgba(39,167,68,.25)}
        .btn-ap:hover{background:rgba(39,167,68,.28);transform:translateY(-1px)}
        .btn-rj{background:var(--red-badge);color:var(--red-badge-t);border-color:rgba(239,68,68,.2)}
        .btn-rj:hover{background:rgba(239,68,68,.22);transform:translateY(-1px)}

        .empty-row td{text-align:center;padding:40px;color:var(--text-d);font-size:12.5px}

        .view-all-wrap{display:flex;justify-content:center;padding:14px 0 4px}
        .btn-outline{padding:7px 24px;border:1px solid rgba(255,255,255,.12);border-radius:7px;font-size:12px;font-weight:600;color:var(--text-m);background:transparent;cursor:pointer;font-family:inherit;transition:all .15s}
        .btn-outline:hover{border-color:var(--green);color:var(--green);background:var(--green-glow2)}

        #toast{position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:9px;font-size:12.5px;font-weight:500;background:#1f2937;color:#fff;opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;z-index:999;pointer-events:none;display:flex;align-items:center;gap:7px;box-shadow:0 8px 24px rgba(0,0,0,.4)}
        #toast.show{opacity:1;transform:translateY(0)}
        #toast.ok{background:#052e16;border:1px solid rgba(39,167,68,.3)}
        #toast.fail{background:#450a0a;border:1px solid rgba(239,68,68,.3)}

        .top-accent{height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);position:absolute;top:0;left:0;right:0}
        .stat-icon[onclick]:hover{background:rgba(39,167,68,.28);transform:scale(1.1);transition:all .15s}
        .dropdown-wrap{position:relative;display:inline-block}
        .dot-btn{background:transparent;border:none;color:var(--text-m);cursor:pointer;padding:4px 6px;border-radius:6px;display:flex;align-items:center;justify-content:center;transition:all .15s}
        .dot-btn:hover{background:var(--glass);color:var(--text)}
        .dropdown-menu{display:none;position:absolute;right:0;top:32px;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:10px;min-width:180px;z-index:100;padding:4px;box-shadow:0 8px 24px rgba(0,0,0,.4)}
        .dropdown-menu.open{display:block}
        .dropdown-item{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:7px;font-size:12.5px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;white-space:nowrap}
        .dropdown-item:hover{background:var(--glass);color:var(--text)}
        .dropdown-item.danger{color:var(--red-badge-t)}
        .dropdown-item.danger:hover{background:rgba(239,68,68,.08);color:#f87171}
        .dropdown-item.reactivate{color:#5fdd8e}
        .dropdown-item.reactivate:hover{background:rgba(39,167,68,.08);color:#4ade80}
    </style>
</head>
<body>

<div class="top-accent"></div>
<div style="display:flex;min-height:100vh;width:100%;position:relative">

<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-logo">
      <svg viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div>
      <div class="sb-brand-name">SSG Finance</div>
      <div class="sb-brand-sub">Admin Panel</div>
    </div>
  </div>

  <div class="sb-label">Main</div>
  <a class="nav-item active" id="nav-dashboard" onclick="showPage('dashboard',this)">
    <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
    Dashboard
  </a>
  <a class="nav-item" id="nav-requests" onclick="showPage('requests',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><rect x="9" y="3" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Requests
    @if ((Model.RequestedAccounts?.Count ?? 0) > 0)
    {
        <span class="nav-badge">@Model.RequestedAccounts!.Count</span>
    }
  </a>

  <div class="sb-label">Users</div>
  <a class="nav-item" id="nav-students" onclick="showPage('students',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c0 1.657 2.686 3 6 3s6-1.343 6-3v-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Students
  </a>
  <a class="nav-item" id="nav-treasurers" onclick="showPage('treasurers',this)">
    <svg viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M16 11a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M7 7V5a5 5 0 0110 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Treasurers
  </a>
  <a class="nav-item" id="nav-professors" onclick="showPage('professors',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Professors
  </a>
  <a class="nav-item" id="nav-admins" onclick="showPage('admins',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Admins
  </a>

  <div class="sb-label">System</div>
  <a class="nav-item" id="nav-settings" onclick="showPage('settings',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="1.8"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="1.8"/></svg>
    Settings
  </a>

  <div class="sb-spacer"></div>
  <div class="sb-user">
    <div class="user-card">
      <div class="user-av">@initials.ToUpper()</div>
      <div>
        <div class="user-name">@(lastName.Length > 0 ? $"Ms. {lastName}" : firstName)</div>
        <div class="user-role">Administrator</div>
      </div>
    </div>
    <div class="signout" onclick="window.location.href='@Url.Action("Logout", "Home")'">
      <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Sign Out
    </div>
  </div>
</aside>

<div class="main">

  <!-- DASHBOARD PAGE -->
  <div class="page active" id="page-dashboard">
    <div class="page-hdr">
      <div>
        <div class="page-title">Dashboard</div>
        <div class="page-sub">Welcome back, @firstName</div>
      </div>
      <div style="font-size:11.5px;color:var(--text-m);background:rgba(39,167,68,.1);border:1px solid rgba(39,167,68,.2);padding:6px 13px;border-radius:8px;display:flex;align-items:center;gap:6px">
        <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;display:inline-block"></span>
        System Online
      </div>
    </div>

    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-lbl">Registered Accounts</div>
        <div class="stat-row">
          <div class="stat-val">@Model.ApprovedAccountsCount</div>
          <div class="stat-icon g">
            <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#27a744" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#27a744" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="#27a744" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
        </div>
        <div class="stat-trend">All approved accounts</div>
      </div>
      <div class="stat-card">
        <div class="stat-lbl">Pending Requests</div>
        <div class="stat-row">
          <div class="stat-val">@(Model.RequestedAccounts?.Count ?? 0)</div>
          <div class="stat-icon y">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#fbbf24" stroke-width="1.8"/><path d="M12 8v4l3 3" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
        </div>
        <div class="stat-trend @((Model.RequestedAccounts?.Count ?? 0) == 0 ? "" : "warn")">
    @((Model.RequestedAccounts?.Count ?? 0) == 0 ? "No pending requests" : "Awaiting review")
</div>
      </div>
      <div class="stat-col">
        <div class="stat-card stat-card-half">
          <div class="stat-lbl">Students</div>
          <div class="stat-row">
            <div class="stat-val">@(Model.Students?.Count ?? 0)</div>
            <div class="stat-icon g" onclick="showPage('students',document.getElementById('nav-students'))" style="cursor:pointer" title="View Students">
            <svg viewBox="0 0 24 24" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="#27a744" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          </div>
          <div class="stat-trend">Approved</div>
        </div>
        <div class="stat-card stat-card-half">
          <div class="stat-lbl">Treasurers</div>
          <div class="stat-row">
            <div class="stat-val">@(Model.Treasurers?.Count ?? 0)</div>
            <div class="stat-icon g" onclick="showPage('treasurers',document.getElementById('nav-treasurers'))" style="cursor:pointer" title="View Treasurers">
              <svg viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#27a744" stroke-width="1.8"/><path d="M16 11a4 4 0 01-8 0" stroke="#27a744" stroke-width="1.8" stroke-linecap="round"/></svg>
            </div>
          </div>
          <div class="stat-trend">Approved</div>
        </div>
      </div>
      <div class="stat-col">
        <div class="stat-card stat-card-half">
          <div class="stat-lbl">Professors</div>
          <div class="stat-row">
            <div class="stat-val">@(Model.Professors?.Count ?? 0)</div>
            <div class="stat-icon g" onclick="showPage('professors',document.getElementById('nav-professors'))" style="cursor:pointer" title="View Professors">
              <svg viewBox="0 0 24 24" fill="none"><path d="M12 14l9-5-9-5-9 5 9 5z" stroke="#27a744" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>
          <div class="stat-trend">Approved</div>
        </div>
        <div class="stat-card stat-card-half">
          <div class="stat-lbl">Admins</div>
          <div class="stat-row">
            <div class="stat-val">@(Model.Admins?.Count ?? 0)</div>
            <div class="stat-icon g" onclick="showPage('admins',document.getElementById('nav-admins'))" style="cursor:pointer" title="View Admins">
              <svg viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#27a744" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>
          <div class="stat-trend">Approved</div>
        </div>
      </div>
    </div>

    <div class="content-card">
      <div class="cc-hdr">
        <div class="cc-title">Recent Account Requests</div>
        <span class="badge by">@(Model.AllAccountRequests?.Count ?? 0) total</span>
      </div>
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr><th>School ID</th><th>Name</th><th>Course</th><th>Year &amp; Section</th><th>Date</th><th>Status</th></tr>
          </thead>
          <tbody id="recent-tbody">
            @if (Model.AllAccountRequests != null && Model.AllAccountRequests.Any())
            {
                int idx = 0;
                @foreach (var acct in Model.AllAccountRequests)
                {
                    var hidden = idx >= 5 ? "display:none" : "";
                    <tr class="recent-row" style="@hidden">
                        <td class="td-mono td-m">@(acct.SchoolId ?? "—")</td>
                        <td><strong>@acct.Fullname</strong></td>
                        <td class="td-m">@(acct.CourseCode ?? "—")</td>
                        <td class="td-m">@(acct.YearLevel ?? "—")-@(acct.Section ?? "—")</td>
                        <td class="td-mono td-m">@acct.CreatedAt.ToString("MM-dd-yyyy")</td>
                        <td>
                            @{
                                var statusClass = acct.Status switch
                                {
                                    RequestStatus.Pending  => "by",
                                    RequestStatus.Approved => "bg",
                                    RequestStatus.Rejected => "br",
                                    _                      => "by"
                                };
                            }
                            <span class="badge @statusClass">@acct.Status</span>
                        </td>
                    </tr>
                    idx++;
                }
            }
            else
            {
                <tr class="empty-row"><td colspan="6">No account requests found.</td></tr>
            }
          </tbody>
        </table>
      </div>
      @if ((Model.AllAccountRequests?.Count ?? 0) > 5)
      {
          <div class="view-all-wrap">
              <button class="btn-outline" id="view-all-btn" 
                      data-total="@Model.AllAccountRequests!.Count"
                      data-expanded="false"
                      onclick="toggleRecentRows()">
                  View All (@Model.AllAccountRequests!.Count)
              </button>
          </div>
      }
    </div>
